---
import Layout from '../../layouts/Layout.astro';
import { getSession } from '../../lib/auth';
import { KVStore } from '../../lib/kv';

const session = getSession(Astro.cookies);

if (!session || session.role !== 'admin') {
  return Astro.redirect('/login');
}

const { KV } = Astro.locals.runtime.env;
const kvStore = new KVStore({ KV });
const debtors = await kvStore.getDebtors();
const transactions = await kvStore.getTransactions();

let totalDebt = 0;
const debtorsWithBalance = await Promise.all(
  debtors.map(async (d) => {
    const balance = await kvStore.getDebtorBalance(d.id);
    totalDebt += balance;
    return { ...d, balance };
  })
);

const recentTx = transactions
  .sort((a, b) => b.createdAt - a.createdAt)
  .slice(0, 5);
---

<Layout title="Dashboard" user={{ username: session.username, role: session.role }}>
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-white">Dashboard</h1>
        <p class="text-slate-400 text-sm mt-1">Selamat datang, {session.username}</p>
      </div>
      <div class="w-12 h-12 bg-blue-500/20 rounded-xl flex items-center justify-center">
        <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
      </div>
    </div>

    <div class="bg-gradient-to-br from-red-500/20 to-red-600/10 rounded-2xl p-5 border border-red-500/20">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-slate-400 text-sm">Total Hutang</p>
          <p class="text-3xl font-bold text-white mt-1">Rp {totalDebt.toLocaleString('id-ID')}</p>
        </div>
        <div class="w-14 h-14 bg-red-500/30 rounded-2xl flex items-center justify-center">
          <svg class="w-7 h-7 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
      </div>
      <div class="mt-3 flex items-center justify-between text-sm">
        <span class="text-slate-400">{debtors.length} orang</span>
        <a href="/admin/debtors" class="text-red-400 hover:text-red-300 font-medium">Lihat semua →</a>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <a href="/admin/debtors" class="bg-gradient-to-br from-red-500/20 to-red-600/10 rounded-2xl p-5 border border-red-500/20 hover:border-red-500/40 transition-all">
        <div class="w-10 h-10 bg-red-500/30 rounded-xl flex items-center justify-center mb-3">
          <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
        </div>
        <h3 class="font-semibold text-white mb-1">Hutang</h3>
        <p class="text-xs text-slate-400">Kelola data hutang</p>
      </a>

      <a href="/admin/notes" class="bg-gradient-to-br from-blue-500/20 to-blue-600/10 rounded-2xl p-5 border border-blue-500/20 hover:border-blue-500/40 transition-all">
        <div class="w-10 h-10 bg-blue-500/30 rounded-xl flex items-center justify-center mb-3">
          <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <h3 class="font-semibold text-white mb-1">Notes</h3>
        <p class="text-xs text-slate-400">Kelola catatan</p>
      </a>
    </div>

    {recentTx.length > 0 && (
      <div class="bg-slate-800/50 rounded-2xl p-5 border border-slate-700/50">
        <h3 class="font-semibold text-white mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Transaksi Terakhir
        </h3>
        <div class="space-y-3">
          {recentTx.map((tx) => (
            <div class="flex items-center justify-between py-2 border-b border-slate-700/50 last:border-0">
              <div class="flex items-center gap-3">
                <div class={`w-10 h-10 rounded-xl flex items-center justify-center ${
                  tx.type === 'debt' 
                    ? 'bg-red-500/20 text-red-400' 
                    : 'bg-green-500/20 text-green-400'
                }`}>
                  {tx.type === 'debt' ? (
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 13l-5 5m0 0l-5-5m5 5V6" />
                    </svg>
                  ) : (
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
                    </svg>
                  )}
                </div>
                <div>
                  <p class="text-white text-sm font-medium">{tx.description}</p>
                  <p class="text-xs text-slate-500">{new Date(tx.createdAt).toLocaleDateString('id-ID')}</p>
                </div>
              </div>
              <span class={`font-semibold ${
                tx.type === 'debt' ? 'text-red-400' : 'text-green-400'
              }`}>
                {tx.type === 'debt' ? '+' : '-'}Rp {tx.amount.toLocaleString('id-ID')}
              </span>
            </div>
          ))}
        </div>
      </div>
    )}

    <div class="bg-slate-800/50 rounded-2xl p-5 border border-slate-700/50">
      <h3 class="font-semibold text-white mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Info Admin
      </h3>
      <div class="space-y-3 text-sm">
        <div class="flex justify-between py-2 border-b border-slate-700/50">
          <span class="text-slate-400">Username</span>
          <span class="text-white font-medium">{session.username}</span>
        </div>
        <div class="flex justify-between py-2 border-b border-slate-700/50">
          <span class="text-slate-400">Role</span>
          <span class="text-blue-400 font-medium">Administrator</span>
        </div>
        <div class="flex justify-between py-2">
          <span class="text-slate-400">Akses</span>
          <span class="text-green-400 font-medium">Full Access</span>
        </div>
      </div>
    </div>
  </div>
</Layout>
