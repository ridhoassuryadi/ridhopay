---
import Layout from '../../../layouts/Layout.astro';
import { getSession } from '../../../lib/auth';
import { KVStore } from '../../../lib/kv';

const session = getSession(Astro.cookies);

if (!session || session.role !== 'admin') {
  return Astro.redirect('/login');
}

const { KV } = Astro.locals.runtime.env;
const kvStore = new KVStore({ KV });

const debtorId = Astro.params.id;
if (!debtorId) {
  return Astro.redirect('/admin/debtors');
}

const debtor = await kvStore.getDebtorById(debtorId);
if (!debtor) {
  return Astro.redirect('/admin/debtors');
}

const transactions = await kvStore.getTransactionByDebtorId(debtorId);
const balance = await kvStore.getDebtorBalance(debtorId);

let message = '';
let messageType = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get('_action')?.toString();
    
    if (action === 'add-debt') {
      const amount = parseInt(formData.get('amount')?.toString() || '0');
      const description = formData.get('description')?.toString() || 'Hutang';
      
      if (amount > 0) {
        await kvStore.createTransaction({
          debtorId,
          type: 'debt',
          amount,
          description,
          createdBy: session.userId,
        });
        return Astro.redirect(`/admin/debtors/${debtorId}?success=added`);
      }
    } else if (action === 'add-payment') {
      const amount = parseInt(formData.get('amount')?.toString() || '0');
      const description = formData.get('description')?.toString() || 'Pembayaran';
      
      if (amount > 0) {
        await kvStore.createTransaction({
          debtorId,
          type: 'payment',
          amount,
          description,
          createdBy: session.userId,
        });
        return Astro.redirect(`/admin/debtors/${debtorId}?success=paid`);
      }
    } else if (action === 'delete-tx') {
      const txId = formData.get('txId')?.toString();
      if (txId) {
        await kvStore.deleteTransaction(txId);
        return Astro.redirect(`/admin/debtors/${debtorId}?success=deleted`);
      }
    } else if (action === 'update') {
      const name = formData.get('name')?.toString() || '';
      const phone = formData.get('phone')?.toString() || '';
      const address = formData.get('address')?.toString() || '';
      const notes = formData.get('notes')?.toString() || '';
      
      if (name) {
        await kvStore.updateDebtor(debtorId, { name, phone, address, notes });
        return Astro.redirect(`/admin/debtors/${debtorId}?success=updated`);
      }
    }
  } catch (e) {
    message = 'Terjadi kesalahan';
    messageType = 'error';
  }
}

const successParam = Astro.url.searchParams.get('success');
if (successParam === 'added') message = 'Hutang berhasil ditambahkan';
if (successParam === 'paid') message = 'Pembayaran berhasil dicatat';
if (successParam === 'deleted') message = 'Transaksi berhasil dihapus';
if (successParam === 'updated') message = 'Data berhasil diperbarui';
if (successParam) messageType = 'success';
---

<Layout title={debtor.name} user={{ username: session.username, role: session.role }}>
  <div class="space-y-6">
    <div class="flex items-center gap-4">
      <a href="/admin/debtors" class="w-10 h-10 bg-slate-700 rounded-xl flex items-center justify-center text-slate-400 hover:text-white transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </a>
      <h1 class="text-xl font-bold text-white">Detail</h1>
    </div>

    {message && (
      <div class={`p-4 rounded-xl text-sm ${
        messageType === 'success' 
          ? 'bg-green-500/10 border border-green-500/30 text-green-400'
          : 'bg-red-500/10 border border-red-500/30 text-red-400'
      }`}>
        {message}
      </div>
    )}

    <div class={`rounded-2xl p-5 border ${
      balance > 0 
        ? 'bg-gradient-to-br from-red-500/20 to-red-600/10 border-red-500/20' 
        : 'bg-gradient-to-br from-green-500/20 to-green-600/10 border-green-500/20'
    }`}>
      <div class="flex items-center gap-4">
        <div class="w-16 h-16 bg-red-500/30 rounded-2xl flex items-center justify-center">
          <span class="text-2xl font-bold text-red-400">
            {debtor.name.charAt(0).toUpperCase()}
          </span>
        </div>
        <div class="flex-1">
          <h2 class="text-xl font-bold text-white">{debtor.name}</h2>
          {debtor.phone && (
            <p class="text-slate-400 text-sm">{debtor.phone}</p>
          )}
          {debtor.address && (
            <p class="text-slate-500 text-xs mt-1">{debtor.address}</p>
          )}
        </div>
      </div>
      <div class="mt-5 pt-5 border-t border-slate-700/50 flex items-center justify-between">
        <div>
          <p class="text-slate-400 text-sm">{balance > 0 ? 'Sisa Hutang' : 'Status'}</p>
          <p class={`text-2xl font-bold mt-1 ${balance > 0 ? 'text-red-400' : 'text-green-400'}`}>
            {balance > 0 ? `Rp ${balance.toLocaleString('id-ID')}` : 'LUNAS'}
          </p>
        </div>
        <button 
          onclick="document.getElementById('editModal').classList.remove('hidden')"
          class="px-4 py-2 bg-slate-700 hover:bg-slate-600 text-white rounded-xl text-sm font-medium transition-colors"
        >
          Edit
        </button>
      </div>
    </div>

    <div id="editModal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-end sm:items-center justify-center p-4">
      <div class="bg-slate-800 rounded-t-3xl sm:rounded-2xl w-full max-w-lg max-h-[85vh] overflow-auto">
        <div class="p-6">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-white">Edit Debitur</h2>
            <button 
              onclick="document.getElementById('editModal').classList.add('hidden')"
              class="w-10 h-10 bg-slate-700 rounded-xl flex items-center justify-center text-slate-400 hover:text-white transition-colors"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
          
          <form method="POST" class="space-y-4">
            <input type="hidden" name="_action" value="update" />
            
            <div>
              <label class="block text-sm font-medium text-slate-300 mb-2">Nama</label>
              <input 
                type="text" 
                name="name" 
                required
                value={debtor.name}
                class="w-full px-4 py-3 bg-slate-700/50 border border-slate-600 rounded-xl text-white focus:outline-none focus:ring-2 focus:ring-blue-500"
              />
            </div>
            
            <div>
              <label class="block text-sm font-medium text-slate-300 mb-2">No. HP</label>
              <input 
                type="tel" 
                name="phone"
                value={debtor.phone || ''}
                class="w-full px-4 py-3 bg-slate-700/50 border border-slate-600 rounded-xl text-white focus:outline-none focus:ring-2 focus:ring-blue-500"
              />
            </div>
            
            <div>
              <label class="block text-sm font-medium text-slate-300 mb-2">Alamat</label>
              <textarea 
                name="address" 
                rows="2"
                class="w-full px-4 py-3 bg-slate-700/50 border border-slate-600 rounded-xl text-white focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"
              >{debtor.address || ''}</textarea>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-slate-300 mb-2">Catatan</label>
              <textarea 
                name="notes" 
                rows="2"
                class="w-full px-4 py-3 bg-slate-700/50 border border-slate-600 rounded-xl text-white focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"
              >{debtor.notes || ''}</textarea>
            </div>
            
            <button 
              type="submit"
              class="w-full py-3 bg-blue-500 hover:bg-blue-600 text-white font-semibold rounded-xl transition-colors"
            >
              Simpan
            </button>
          </form>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <button 
        onclick="document.getElementById('addDebtModal').classList.remove('hidden')"
        class="bg-gradient-to-br from-red-500/20 to-red-600/10 rounded-2xl p-4 border border-red-500/20 hover:border-red-500/40 transition-all text-center"
      >
        <div class="w-12 h-12 bg-red-500/30 rounded-xl flex items-center justify-center mx-auto mb-2">
          <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 13l-5 5m0 0l-5-5m5 5V6" />
          </svg>
        </div>
        <p class="font-semibold text-white">Tambah Hutang</p>
      </button>
      
      <button 
        onclick="document.getElementById('addPaymentModal').classList.remove('hidden')"
        class="bg-gradient-to-br from-green-500/20 to-green-600/10 rounded-2xl p-4 border border-green-500/20 hover:border-green-500/40 transition-all text-center"
      >
        <div class="w-12 h-12 bg-green-500/30 rounded-xl flex items-center justify-center mx-auto mb-2">
          <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
          </svg>
        </div>
        <p class="font-semibold text-white">Bayar</p>
      </button>
    </div>

    <div id="addDebtModal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-end sm:items-center justify-center p-4">
      <div class="bg-slate-800 rounded-t-3xl sm:rounded-2xl w-full max-w-lg">
        <div class="p-6">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-white">Tambah Hutang</h2>
            <button 
              onclick="document.getElementById('addDebtModal').classList.add('hidden')"
              class="w-10 h-10 bg-slate-700 rounded-xl flex items-center justify-center text-slate-400 hover:text-white transition-colors"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
          
          <form method="POST" class="space-y-4">
            <input type="hidden" name="_action" value="add-debt" />
            
            <div>
              <label class="block text-sm font-medium text-slate-300 mb-2">Jumlah (Rp)</label>
              <input 
                type="number" 
                name="amount" 
                required
                min="1"
                class="w-full px-4 py-3 bg-slate-700/50 border border-slate-600 rounded-xl text-white text-xl font-bold focus:outline-none focus:ring-2 focus:ring-red-500"
                placeholder="0"
              />
            </div>
            
            <div>
              <label class="block text-sm font-medium text-slate-300 mb-2">Keterangan</label>
              <input 
                type="text" 
                name="description"
                class="w-full px-4 py-3 bg-slate-700/50 border border-slate-600 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-red-500"
                placeholder="Contoh: Pinjaman tanggal 1"
              />
            </div>
            
            <button 
              type="submit"
              class="w-full py-3 bg-red-500 hover:bg-red-600 text-white font-semibold rounded-xl transition-colors"
            >
              Tambah Hutang
            </button>
          </form>
        </div>
      </div>
    </div>

    <div id="addPaymentModal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-end sm:items-center justify-center p-4">
      <div class="bg-slate-800 rounded-t-3xl sm:rounded-2xl w-full max-w-lg">
        <div class="p-6">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-white">Pembayaran</h2>
            <button 
              onclick="document.getElementById('addPaymentModal').classList.add('hidden')"
              class="w-10 h-10 bg-slate-700 rounded-xl flex items-center justify-center text-slate-400 hover:text-white transition-colors"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
          
          <form method="POST" class="space-y-4">
            <input type="hidden" name="_action" value="add-payment" />
            
            <div>
              <label class="block text-sm font-medium text-slate-300 mb-2">Jumlah (Rp)</label>
              <input 
                type="number" 
                name="amount" 
                required
                min="1"
                max={balance}
                class="w-full px-4 py-3 bg-slate-700/50 border border-slate-600 rounded-xl text-white text-xl font-bold focus:outline-none focus:ring-2 focus:ring-green-500"
                placeholder="0"
              />
            </div>
            
            <div>
              <label class="block text-sm font-medium text-slate-300 mb-2">Keterangan</label>
              <input 
                type="text" 
                name="description"
                class="w-full px-4 py-3 bg-slate-700/50 border border-slate-600 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-green-500"
                placeholder="Contoh: Bayar sebagian"
              />
            </div>
            
            <button 
              type="submit"
              class="w-full py-3 bg-green-500 hover:bg-green-600 text-white font-semibold rounded-xl transition-colors"
            >
              Bayar
            </button>
          </form>
        </div>
      </div>
    </div>

    <div class="bg-slate-800/50 rounded-2xl p-5 border border-slate-700/50">
      <h3 class="font-semibold text-white mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Riwayat Transaksi
      </h3>
      
      {transactions.length === 0 ? (
        <div class="text-center py-8">
          <p class="text-slate-400">Belum ada transaksi</p>
        </div>
      ) : (
        <div class="space-y-3">
          {transactions.map((tx) => (
            <div class="flex items-center justify-between py-3 border-b border-slate-700/50 last:border-0 group">
              <div class="flex items-center gap-3">
                <div class={`w-10 h-10 rounded-xl flex items-center justify-center ${
                  tx.type === 'debt' 
                    ? 'bg-red-500/20 text-red-400' 
                    : 'bg-green-500/20 text-green-400'
                }`}>
                  {tx.type === 'debt' ? (
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 13l-5 5m0 0l-5-5m5 5V6" />
                    </svg>
                  ) : (
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
                    </svg>
                  )}
                </div>
                <div>
                  <p class="text-white text-sm font-medium">{tx.description}</p>
                  <p class="text-xs text-slate-500">
                    {new Date(tx.createdAt).toLocaleDateString('id-ID', { 
                      day: 'numeric', 
                      month: 'short', 
                      year: 'numeric',
                      hour: '2-digit',
                      minute: '2-digit'
                    })}
                  </p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <span class={`font-semibold ${
                  tx.type === 'debt' ? 'text-red-400' : 'text-green-400'
                }`}>
                  {tx.type === 'debt' ? '+' : '-'}Rp {tx.amount.toLocaleString('id-ID')}
                </span>
                <form method="POST" class="opacity-0 group-hover:opacity-100 transition-opacity">
                  <input type="hidden" name="_action" value="delete-tx" />
                  <input type="hidden" name="txId" value={tx.id} />
                  <button 
                    type="submit"
                    class="w-8 h-8 bg-red-500/20 hover:bg-red-500/30 rounded-lg flex items-center justify-center text-red-400 transition-colors"
                    onclick="return confirm('Hapus transaksi ini?')"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                  </button>
                </form>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>

    {debtor.notes && (
      <div class="bg-slate-800/50 rounded-2xl p-5 border border-slate-700/50">
        <h3 class="font-semibold text-white mb-3 flex items-center gap-2">
          <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
          </svg>
          Catatan
        </h3>
        <p class="text-slate-400 text-sm whitespace-pre-wrap">{debtor.notes}</p>
      </div>
    )}

    <form method="POST" onsubmit="return confirm('Hapus data ini beserta semua transaksinya?')">
      <input type="hidden" name="_action" value="delete" />
      <button 
        type="submit"
        class="w-full py-3 bg-red-500/10 hover:bg-red-500/20 text-red-400 font-medium rounded-xl transition-colors border border-red-500/20"
      >
        Hapus Data Debitur
      </button>
    </form>
  </div>
</Layout>
