---
import Layout from '../../layouts/Layout.astro';
import { getOrCreateGuestSession } from '../../lib/auth';
import { KVStore } from '../../lib/kv';

const guest = getOrCreateGuestSession(Astro.cookies);

const { KV } = Astro.locals.runtime.env;
const kvStore = new KVStore({ KV });
const allNotes = await kvStore.getNotes();
const guestNotes = allNotes.filter(n => n.authorId === guest.userId);
const sortedNotes = guestNotes.sort((a, b) => b.updatedAt - a.updatedAt);

let message = '';
let messageType = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get('_action')?.toString();
    
    if (action === 'create') {
      const title = formData.get('title')?.toString() || '';
      const content = formData.get('content')?.toString() || '';
      
      if (title && content) {
        await kvStore.createNote({
          title,
          content,
          authorId: guest.userId,
          authorRole: 'guest',
        });
        return Astro.redirect('/guest/notes?success=created');
      }
    } else if (action === 'delete') {
      const id = formData.get('id')?.toString();
      const note = await kvStore.getNoteById(id || '');
      
      if (note && note.authorId === guest.userId) {
        await kvStore.deleteNote(id!);
        return Astro.redirect('/guest/notes?success=deleted');
      }
    }
  } catch (e) {
    message = 'Terjadi kesalahan';
    messageType = 'error';
  }
}

const successParam = Astro.url.searchParams.get('success');
if (successParam === 'created') message = 'Catatan berhasil dibuat';
if (successParam === 'deleted') message = 'Catatan berhasil dihapus';
if (successParam) messageType = 'success';
---

<Layout title="Notes" isGuest={true}>
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-white">Catatan Saya</h1>
        <p class="text-slate-400 text-sm mt-1">{guestNotes.length} catatan</p>
      </div>
      <button 
        onclick="document.getElementById('createModal').classList.remove('hidden')"
        class="px-4 py-2 bg-green-500 hover:bg-green-600 text-white rounded-xl text-sm font-medium transition-colors"
      >
        + Baru
      </button>
    </div>

    {message && (
      <div class={`p-4 rounded-xl text-sm ${
        messageType === 'success' 
          ? 'bg-green-500/10 border border-green-500/30 text-green-400'
          : 'bg-red-500/10 border border-red-500/30 text-red-400'
      }`}>
        {message}
      </div>
    )}

    <div id="createModal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-end sm:items-center justify-center p-4">
      <div class="bg-slate-800 rounded-t-3xl sm:rounded-2xl w-full max-w-lg max-h-[80vh] overflow-auto">
        <div class="p-6">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-white">Catatan Baru</h2>
            <button 
              onclick="document.getElementById('createModal').classList.add('hidden')"
              class="w-10 h-10 bg-slate-700 rounded-xl flex items-center justify-center text-slate-400 hover:text-white transition-colors"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
          
          <form method="POST" class="space-y-4">
            <input type="hidden" name="_action" value="create" />
            
            <div>
              <label class="block text-sm font-medium text-slate-300 mb-2">Judul</label>
              <input 
                type="text" 
                name="title" 
                required
                class="w-full px-4 py-3 bg-slate-700/50 border border-slate-600 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-green-500"
                placeholder="Judul catatan"
              />
            </div>
            
            <div>
              <label class="block text-sm font-medium text-slate-300 mb-2">Konten</label>
              <textarea 
                name="content" 
                required
                rows="5"
                class="w-full px-4 py-3 bg-slate-700/50 border border-slate-600 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-green-500 resize-none"
                placeholder="Isi catatan..."
              ></textarea>
            </div>
            
            <button 
              type="submit"
              class="w-full py-3 bg-green-500 hover:bg-green-600 text-white font-semibold rounded-xl transition-colors"
            >
              Simpan
            </button>
          </form>
        </div>
      </div>
    </div>

    {sortedNotes.length === 0 ? (
      <div class="text-center py-16">
        <div class="w-16 h-16 mx-auto mb-4 bg-slate-800 rounded-2xl flex items-center justify-center">
          <svg class="w-8 h-8 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <p class="text-slate-400">Belum ada catatan</p>
        <p class="text-slate-500 text-sm mt-1">Buat catatan pertama Anda</p>
      </div>
    ) : (
      <div class="space-y-3">
        {sortedNotes.map((note) => (
          <div class="bg-slate-800/50 rounded-2xl p-5 border border-slate-700/50 group hover:border-green-500/30 transition-all">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <h3 class="font-semibold text-white truncate">{note.title}</h3>
                <p class="text-slate-400 text-sm mt-1 line-clamp-2">{note.content}</p>
                <div class="flex items-center gap-3 mt-3 text-xs text-slate-500">
                  <span>{new Date(note.updatedAt).toLocaleDateString('id-ID')}</span>
                </div>
              </div>
              <form method="POST" class="opacity-0 group-hover:opacity-100 transition-opacity">
                <input type="hidden" name="_action" value="delete" />
                <input type="hidden" name="id" value={note.id} />
                <button 
                  type="submit"
                  class="w-10 h-10 bg-red-500/20 hover:bg-red-500/30 rounded-xl flex items-center justify-center text-red-400 transition-colors"
                  onclick="return confirm('Hapus catatan ini?')"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                </button>
              </form>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</Layout>
